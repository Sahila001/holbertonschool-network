#!/usr/bin/env bash
# Configures local IP mappings for localhost and facebook.com in /etc/hosts

# Change localhost resolution from 127.0.0.1 to 127.0.0.2
sed -i 's/127.0.0.1\s*localhost/127.0.0.2 localhost/' /etc/hosts

# Ensure facebook.com maps to 8.8.8.8 without causing duplicate entries if rerun
if grep -q "facebook.com" /etc/hosts; then
    sed -i 's/.*facebook.com.*/8.8.8.8 facebook.com/' /etc/hosts
else
    echo "8.8.8.8 facebook.com" >> /etc/hosts
fi